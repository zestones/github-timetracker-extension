{
  "name": "github-time-tracker",
  "private": true,
  "version": "1.0.2",
  "type": "module",
  "scripts": {
    "watch": "nodemon --watch src --ext js,jsx,html,css,json --exec \"npm run build\"",
    "build:popup": "vite build --config vite.config.popup.js",
    "build:background": "vite build --config vite.config.background.js",
    "build:content": "vite build --config vite.config.content.js",
    "build": "rm -rf dist && npm run build:popup && npm run build:background && npm run build:content",
    "typecheck": "tsc -p jsconfig.json --noEmit",
    "lint": "biome lint ./src",
    "format": "biome format --write ./src",
    "check": "biome check --write ./src",
    "validate": "npm run typecheck && biome check ./src"
  },
  "dependencies": {
    "@preact/preset-vite": "^2.5.0",
    "@tailwindcss/vite": "^4.1.6",
    "preact": "^10.19.3",
    "tailwindcss": "^4.1.6"
  },
  "devDependencies": {
    "@biomejs/biome": "2.4.6",
    "@types/chrome": "^0.1.37",
    "nodemon": "^3.1.10",
    "typescript": "^5.9.3",
    "vite": "^6.3.5",
    "vite-plugin-css-injected-by-js": "^3.5.2",
    "vite-plugin-static-copy": "^2.3.1"
  }
}