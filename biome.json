{
	"$schema": "https://biomejs.dev/schemas/2.4.6/schema.json",
	"vcs": {
		"enabled": true,
		"clientKind": "git",
		"useIgnoreFile": true
	},
	"files": {
		"includes": [
			"**",
			"!!**/dist"
		]
	},
	"css": {
		"linter": {
			"enabled": false
		},
		"parser": {
			"cssModules": false,
			"tailwindDirectives": true
		}
	},
	"formatter": {
		"enabled": true,
		"indentStyle": "space",
		"indentWidth": 4,
		"lineWidth": 120
	},
	"linter": {
		"enabled": true,
		"rules": {
			"recommended": true,
			"complexity": {
				"noStaticOnlyClass": "off"
			},
			"a11y": {
				"useKeyWithClickEvents": "warn",
				"noNoninteractiveElementToInteractiveRole": "warn",
				"noSvgWithoutTitle": "warn",
				"useValidAriaValues": "warn",
				"noStaticElementInteractions": "warn",
				"useAltText": "warn",
				"useSemanticElements": "warn"
			}
		}
	},
	"javascript": {
		"formatter": {
			"quoteStyle": "single",
			"trailingCommas": "all"
		}
	},
	"assist": {
		"enabled": true,
		"actions": {
			"source": {
				"organizeImports": "on"
			}
		}
	}
}